# ── Google Calendar ────────────────────────────────────────────────────────────
# Your TVSchedule calendar ID (from Google Calendar settings)
CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ── Web UI ────────────────────────────────────────────────────────────────────
PORT=7840                     # External port for the web UI

# ── Tracker settings ───────────────────────────────────────────────────────────
LOOKAHEAD_DAYS=14
DEFAULT_DURATION_MINUTES=60
RUN_INTERVAL_HOURS=6          # Set to 0 to run once and exit (useful for cron)
TIMEZONE=America/New_York
COLOR_ID=10                   # 10 = Basil green

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Paths inside the container (./config/ is mounted at /config)
GOOGLE_CREDENTIALS_FILE=/config/credentials.json
GOOGLE_TOKEN_FILE=/config/token.json

# ── Show list ──────────────────────────────────────────────────────────────────
# Fallback if Home Assistant is not configured
SHOWS_FILE=/config/shows.txt

# ── Home Assistant (optional) ──────────────────────────────────────────────────
# If set, shows are pulled from the HA todo entity instead of shows.txt
# Leave blank to use shows.txt
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
HA_TODO_ENTITY=todo.tvshows
